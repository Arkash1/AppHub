<?xml version="1.0" encoding="utf-8"?>
<!-- Радиальный градиент-фон всех экранов: тёмный с фиолетовым glow вверху. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_base" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="700"
                android:centerX="0.5"
                android:centerY="0.0"
                android:startColor="#337C4DFF"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
