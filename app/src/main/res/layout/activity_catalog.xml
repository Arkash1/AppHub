<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:stateListAnimator="@null"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/catalog_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:layout_scrollFlags="scroll|enterAlways">

            <com.arkashstudio.apphub.ui.common.GradientTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textAppearance="@style/AppHubLogo" />
        </com.google.android.material.appbar.MaterialToolbar>

        <TextView
            android:id="@+id/catalog_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:gravity="center"
            android:textColor="@color/accent_cyan"
            android:textSize="12sp"
            android:background="@color/bg_surface"
            android:visibility="gone" />

        <!-- Офлайн-баннер -->
        <TextView
            android:id="@+id/catalog_offline_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:gravity="center"
            android:text="@string/offline_banner"
            android:textColor="@color/accent_pink"
            android:textSize="12sp"
            android:background="@color/bg_surface"
            android:visibility="gone" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/catalog_tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:tabMode="scrollable"
            app:tabIndicatorColor="@color/accent_cyan"
            app:tabSelectedTextColor="@color/text_primary"
            app:tabTextColor="@color/text_secondary"
            app:tabIndicatorFullWidth="false"
            app:tabRippleColor="@color/ripple_neon" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/catalog_swipe"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/catalog_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="12dp"
                android:scrollbars="vertical"
                android:overScrollMode="never" />

            <LinearLayout
                android:id="@+id/catalog_empty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/catalog_empty"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />
            </LinearLayout>
        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- FAB настроек -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/catalog_fab_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="@string/settings_title"
        app:backgroundTint="@color/bg_surface_elevated"
        app:srcCompat="@drawable/ic_settings"
        app:tint="@color/accent_cyan"
        app:borderWidth="0dp"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
