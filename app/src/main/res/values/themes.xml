<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Базовая тема AppHub: тёмная неоновая -->
    <style name="Theme.AppHub" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Фоны -->
        <item name="android:windowBackground">@drawable/bg_gradient_root</item>
        <item name="android:colorBackground">@color/bg_base</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorSurfaceVariant">@color/bg_surface_elevated</item>

        <!-- Акценты -->
        <item name="colorPrimary">@color/primary_neon</item>
        <item name="colorPrimaryVariant">@color/primary_neon_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Текст -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Ошибки -->
        <item name="colorError">@color/error_red</item>

        <!-- Статус-бар / навигация -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/bg_base</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Системные -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="q">false</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="q">false</item>

        <!-- Material-компоненты -->
        <item name="materialCardViewStyle">@style/Widget.AppHub.CardView</item>
        <item name="textInputStyle">@style/Widget.AppHub.TextInputLayout</item>
    </style>

    <!-- Тема диалогов -->
    <style name="DialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary_neon</item>
        <item name="android:windowBackground">@drawable/bg_dialog</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Карточка -->
    <style name="Widget.AppHub.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/white_10</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- TextInputLayout -->
    <style name="Widget.AppHub.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary_neon</item>
        <item name="boxBackgroundColor">@color/bg_surface_elevated</item>
        <item name="hintTextColor">@color/accent_cyan</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <!-- Капсульные кнопки -->
    <style name="Widget.AppHub.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@null</item>
        <item name="android:background">@drawable/btn_neon</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Заголовок логотипа (имя БЕЗ префикса "TextAppearance." — иначе AAPT ищет
         несуществующий базовый стиль TextAppearance). -->
    <style name="AppHubLogo" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">22sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Подпись разработчика (пасхалка).
         Для «прикольного» эффекта рекомендуется скачать Orbitron.ttf и положить
         в res/font/orbitron_regular.ttf, тогда раскомментировать fontFamily ниже. -->
    <style name="AppHubDevelopedBy">
        <!-- <item name="android:fontFamily">@font/orbitron_regular</item> -->
        <item name="android:fontFamily">monospace</item>
        <item name="android:typeface">monospace</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
    </style>

</resources>
